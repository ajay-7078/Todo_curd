# MongoDB Connection (Required for Vercel)
# Get this from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/todo_app?retryWrites=true&w=majority

# Server Configuration (Optional - for local development)
PORT=3000

# Session Secret (Change this to a random string)
SESSION_SECRET=your-super-secret-key-change-this

# Environment
NODE_ENV=development

# ===== VERCEL DEPLOYMENT SETUP =====
# 1. Copy MONGO_URI value above
# 2. Go to https://vercel.com/your-project/settings/environment-variables
# 3. Add new environment variable:
#    Name: MONGO_URI
#    Value: (paste your MongoDB connection string)
# 4. Redeploy your project
# ===== END VERCEL SETUP =====
