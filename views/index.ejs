<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Todo App</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .icon-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 32px;
            height: 32px;
            border-radius: 8px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: rgba(255, 255, 255, 0.7);
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            font-size: 14px;
            text-decoration: none;
        }

        .icon-btn:hover {
            background: rgba(255, 255, 255, 0.1);
            transform: scale(1.1);
            border-color: rgba(255, 255, 255, 0.2);
        }

        .icon-btn.success:hover {
            background: rgba(16, 185, 129, 0.2);
            border-color: rgba(16, 185, 129, 0.3);
            color: #86EFAC;
        }

        .icon-btn.secondary:hover {
            background: rgba(59, 130, 246, 0.2);
            border-color: rgba(59, 130, 246, 0.3);
            color: #93C5FD;
        }

        .icon-btn.danger:hover {
            background: rgba(236, 72, 153, 0.2);
            border-color: rgba(236, 72, 153, 0.3);
            color: #FCA5A5;
        }
    </style>
</head>

<body>

<%- include('partials/header.ejs') %>

    <div class="mb-8">
        <div class="text-center">
            <h1 class="text-5xl font-bold bg-gradient-to-r from-blue-400 via-purple-400 to-pink-400 bg-clip-text text-transparent mb-2">
                ✨ Your Tasks
            </h1>
            <p class="text-gray-300">Organize and track all your todos</p>
        </div>
    </div>

    <!-- Add Todo Card -->
    <div class="card mb-8">
        <h2 class="text-xl font-bold text-white mb-4">➕ Create New Task</h2>
        <form action="/create" method="POST" class="flex gap-3">
            <input
                type="text"
                name="task"
                placeholder="Enter your task..."
                required
                class="flex-1"
            >
            <button type="submit" class="btn btn-primary whitespace-nowrap">
                Add Task
            </button>
        </form>
    </div>

    <!-- Tasks List -->
    <div>
        <% if (todos.length === 0) { %>
            <div class="card text-center py-12">
                <p class="text-5xl mb-4">📭</p>
                <h3 class="text-xl font-semibold text-gray-300 mb-2">No tasks yet</h3>
                <p class="text-gray-400">Create your first task above to get started!</p>
            </div>
        <% } else { %>
            <div class="space-y-4">
                <h3 class="text-gray-300 font-semibold text-sm uppercase tracking-wide">
                    <%= todos.length %> <%= todos.length === 1 ? 'Task' : 'Tasks' %>
                </h3>

                <% todos.forEach((todo, index) => { %>
                    <div class="card group hover:border-opacity-100 transition-all" style="animation-delay: <%= index * 50 %>ms">
                        <div class="flex items-center justify-between">
                            <div class="flex-1">
                                <p class="text-white text-lg <% if(todo.completed) { %>line-through text-gray-400<% } %>">
                                    <%= todo.task %>
                                </p>
                                <p class="text-xs text-gray-500 mt-1">
                                    <%= todo.createdAt ? new Date(todo.createdAt).toLocaleDateString() : 'Today' %>
                                </p>
                            </div>

                            <div class="flex gap-2 opacity-100 group-hover:opacity-100 transition-opacity">
                                <% if (!todo.completed) { %>
                                    <a href="/toggle/<%= todo._id %>" 
                                       class="icon-btn success" 
                                       title="Mark as complete">
                                        <i class="fas fa-check"></i>
                                    </a>
                                <% } %>

                                <a href="/edit/<%= todo._id %>" 
                                   class="icon-btn secondary"
                                   title="Edit task">
                                    <i class="fas fa-pen-to-square"></i>
                                </a>

                                <a href="/delete/<%= todo._id %>" 
                                   class="icon-btn danger"
                                   title="Delete task"
                                   onclick="return confirm('Are you sure you want to delete this task?')">
                                    <i class="fas fa-trash-can"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>

<%- include('partials/footer.ejs') %>

</body>
</html>