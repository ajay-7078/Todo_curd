<!DOCTYPE html>
<html>
<head>
    <title>Edit Todo</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-900 min-h-screen flex justify-center items-center">

<div class="bg-zinc-800 p-8 rounded w-96">

    <h1 class="text-white text-2xl mb-5">
        Edit Todo
    </h1>

    <form action="/update/<%= todo._id %>" method="POST">

        <input
            type="text"
            name="task"
            value="<%= todo.task %>"
            class="w-full px-4 py-3 rounded bg-zinc-700 text-white mb-4"
        >

        <button
            class="bg-blue-500 text-white px-5 py-3 rounded w-full"
        >
            Update
        </button>

    </form>

</div>

</body>
</html>