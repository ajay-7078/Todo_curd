<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Todo - Todo App</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/style.css">
</head>

<body class="flex items-center justify-center min-h-screen py-8">

    <div class="w-full max-w-md">
        <div class="card">
            <div class="text-center mb-8">
                <h1 class="text-3xl font-bold bg-gradient-to-r from-blue-400 via-purple-400 to-pink-400 bg-clip-text text-transparent mb-2">
                    ✏️ Edit Todo
                </h1>
                <p class="text-gray-300">Update your task</p>
            </div>

            <form action="/update/<%= todo._id %>" method="POST" class="space-y-4">

                <div>
                    <label class="block text-sm font-medium text-gray-300 mb-2">Task Description</label>
                    <textarea
                        name="task"
                        required
                        rows="4"
                        class="w-full"
                        placeholder="Enter your task description..."
                    ><%= todo.task %></textarea>
                </div>

                <div class="flex gap-3">
                    <button type="submit" class="btn btn-primary flex-1">
                        Update Task
                    </button>
                    <a href="/" class="btn btn-secondary flex-1 text-center">
                        Cancel
                    </a>
                </div>

            </form>
        </div>
    </div>

</body>
</html>